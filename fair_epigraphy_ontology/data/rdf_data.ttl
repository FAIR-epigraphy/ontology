###  https://ontology.inscriptiones.org/epont/Epigraphic_Support
epont:Epigraphic_Support rdf:type owl:Class ;
                         rdfs:subClassOf crm:E24 ;
                         skos:definition "Epigraphic Support"@en ;
                         skos:prefLabel "Epigraphic Support"@en .


