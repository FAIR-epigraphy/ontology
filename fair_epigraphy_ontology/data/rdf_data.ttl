epont:Text_Genre rdf:type owl:Class ;
                 rdfs:subClassOf crm:E55 ;
                 skos:definition "Text Genre"@en ;
                 skos:prefLabel "Text Genre"@en .


###  https://ontology.inscriptiones.org/epont/Translation
epont:Translation rdf:type owl:Class ;
                  rdfs:subClassOf crm:E33 ;
                  skos:definition "Translation"@en ;
                  skos:prefLabel "Translation"@en .

