@prefix : <https://ontology.inscriptiones.org/epont/> .
@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix epont: <https://ontology.inscriptiones.org/epont/> .
@prefix lrmoo: <http://iflastandards.info/ns/lrm/lrmoo/> .
@prefix crmsci: <http://www.cidoc-crm.org/extensions/crmsci/> .
@prefix crmtex: <http://www.cidoc-crm.org/extensions/crmtex/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://ontology.inscriptiones.org/epont/> .

<https://ontology.inscriptiones.org/epont/> rdf:type owl:Ontology ;
                                             owl:imports crm: ;
                                             rdfs:comment "An ontology for epigraphic data, reusing CIDOC-CRM, CRMtex, CRMsci, LRMoo, and Dublin Core Terms." ;
                                             rdfs:label "FAIR Epigraphy Ontology (epont)" ;
                                             skos:definition ""@en ;
                                             skos:prefLabel "FAIR Epigraphy Ontology"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.cidoc-crm.org/cidoc-crm/P11_had_participant
crm:P11_had_participant rdf:type owl:ObjectProperty ;
                        rdfs:domain crmsci:S19 ;
                        rdfs:range crm:E39 ;
                        skos:altLabel "participated in"@en ;
                        skos:definition "P11 had participant"@en ;
                        skos:prefLabel "P11 had participant"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P128
crm:P128 rdf:type owl:ObjectProperty ;
         rdfs:domain crmtex:TX1 ;
         rdfs:range crm:E34 ;
         skos:altLabel "is carried by"@en ;
         skos:definition "P128 carries"@en ;
         skos:prefLabel "P128 carries"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P14
crm:P14 rdf:type owl:ObjectProperty ;
        rdfs:domain crmsci:S21 ;
        rdfs:range crm:E39 ;
        skos:altLabel "performed"@en ;
        skos:definition "P14 carried out by"@en ;
        skos:prefLabel "P14 carried out by"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P140
crm:P140 rdf:type owl:ObjectProperty ;
         rdfs:range epont:Epigraphic_Support ;
         skos:altLabel "was attributed by"@en ;
         skos:definition "P140 assigned attribute to"@en ;
         skos:prefLabel "P140 assigned attribute to"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P165_incorporates
crm:P165_incorporates rdf:type owl:ObjectProperty ;
                      skos:definition "P165 incorporates"@en ;
                      skos:prefLabel "P165 incorporates"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P168
crm:P168 rdf:type owl:ObjectProperty ;
         rdfs:domain crm:E53 ;
         rdfs:range crm:E94 ;
         skos:altLabel "defines place"@en ;
         skos:definition "P168 place is defined by"@en ;
         skos:prefLabel "P168 place is defined by"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P2
crm:P2 rdf:type owl:ObjectProperty ;
       rdfs:domain [ rdf:type owl:Class ;
                     owl:unionOf ( crm:E28
                                   crm:E3
                                   crm:E34
                                   crm:E53
                                   crm:E54
                                   crmsci:S19
                                   epont:Epigraphic_Support
                                 )
                   ] ;
       rdfs:range crm:E55 ;
       skos:altLabel "is type of"@en ;
       skos:definition "P2 has type"@en ;
       skos:prefLabel "P2 has type"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P3
crm:P3 rdf:type owl:ObjectProperty ;
       rdfs:domain crm:E53 ;
       rdfs:range crm:E62 ;
       skos:definition "P3 has note"@en ;
       skos:prefLabel "P3 has note"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P34
crm:P34 rdf:type owl:ObjectProperty ;
        rdfs:domain crm:E14 ;
        rdfs:range epont:Epigraphic_Support ;
        skos:altLabel "was assessed by"@en ;
        skos:definition "P34 concerned"@en ;
        skos:prefLabel "P34 concerned"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P35
crm:P35 rdf:type owl:ObjectProperty ;
        rdfs:domain crm:E14 ;
        rdfs:range crm:E3 ;
        skos:altLabel "was identified by"@en ;
        skos:definition "P35 has identified"@en ;
        skos:prefLabel "P35 has identified"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P37
crm:P37 rdf:type owl:ObjectProperty ;
        rdfs:range crm:E42 ;
        skos:altLabel "was assigned by"@en ;
        skos:definition "P37 assigned"@en ;
        skos:prefLabel "P37 assigned"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P4
crm:P4 rdf:type owl:ObjectProperty ;
       rdfs:domain [ rdf:type owl:Class ;
                     owl:unionOf ( crm:E63
                                   crm:E64
                                   crmsci:S19
                                   crmsci:S21
                                 )
                   ] ;
       rdfs:range crm:E52 ;
       skos:altLabel "is time-span of"@en ;
       skos:definition "P4 has time-span"@en ;
       skos:prefLabel "P4 has time-span"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P40_observed_dimension
crm:P40_observed_dimension rdf:type owl:ObjectProperty ;
                           rdfs:domain crmsci:S21 ;
                           rdfs:range crm:E54 ;
                           skos:altLabel "was observed in"@en ;
                           skos:definition "P40 observed dimension"@en ;
                           skos:prefLabel "P40 observed dimension"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P43
crm:P43 rdf:type owl:ObjectProperty ;
        rdfs:domain epont:Epigraphic_Support ;
        rdfs:range crm:E54 ;
        skos:altLabel "is dimension of"@en ;
        skos:definition "P43 has dimension"@en ;
        skos:prefLabel "P43 has dimension"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P45
crm:P45 rdf:type owl:ObjectProperty ;
        rdfs:domain epont:Epigraphic_Support ;
        rdfs:range crm:E57 ;
        skos:altLabel "is incorporated in"@en ;
        skos:definition "P45 consists of"@en ;
        skos:prefLabel "P45 consists of"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P46
crm:P46 rdf:type owl:ObjectProperty ;
        rdfs:domain epont:Epigraphic_Support ;
        skos:altLabel "forms part of"@en ;
        skos:definition "P46 is composed of"@en ;
        skos:prefLabel "P46 is composed of"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P48
crm:P48 rdf:type owl:ObjectProperty ;
        rdfs:domain crm:E53 ;
        rdfs:range crm:E42 ;
        skos:altLabel "is preferred identifier of"@en ;
        skos:definition "P48 has preferred identifier"@en ;
        skos:prefLabel "P48 has preferred identifier"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P55
crm:P55 rdf:type owl:ObjectProperty ;
        rdfs:domain epont:Epigraphic_Support ;
        rdfs:range crm:E53 ;
        skos:altLabel "currently holds"@en ;
        skos:definition "P55 has current location"@en ;
        skos:prefLabel "P55 has current location"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P56
crm:P56 rdf:type owl:ObjectProperty ;
        rdfs:domain epont:Epigraphic_Support ;
        rdfs:range [ rdf:type owl:Class ;
                     owl:unionOf ( crmtex:TX1
                                   crmtex:TX4
                                 )
                   ] ;
        skos:altLabel "is found on"@en ;
        skos:definition "P56 bears feature"@en ;
        skos:prefLabel "P56 bears feature"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P62
crm:P62 rdf:type owl:ObjectProperty ;
        rdfs:domain epont:Epigraphic_Support ;
        rdfs:range crm:E28 ;
        skos:altLabel "is depicted by"@en ;
        skos:definition "P62 depicts"@en ;
        skos:prefLabel "P62 depicts"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P65
crm:P65 rdf:type owl:ObjectProperty ;
        rdfs:domain crmtex:TX1 ;
        rdfs:range crm:E34 ;
        skos:altLabel "is shown by"@en ;
        skos:definition "P65 shows visual item"@en ;
        skos:prefLabel "P65 shows visual item"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P7
crm:P7 rdf:type owl:ObjectProperty ;
       rdfs:domain [ rdf:type owl:Class ;
                     owl:unionOf ( crm:E63
                                   crm:E64
                                 )
                   ] ;
       rdfs:range crm:E53 ;
       skos:altLabel "witnessed"@en ;
       skos:definition "P7 took place at"@en ;
       skos:prefLabel "P7 took place at"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P70
crm:P70 rdf:type owl:ObjectProperty ;
        rdfs:range epont:Epigraphic_Support ;
        skos:altLabel "is documented in"@en ;
        skos:definition "P70 documents"@en ;
        skos:prefLabel "P70 documents"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P72
crm:P72 rdf:type owl:ObjectProperty ;
        rdfs:domain [ rdf:type owl:Class ;
                      owl:unionOf ( crm:E34
                                    epont:Translation
                                  )
                    ] ;
        rdfs:range crm:E56 ;
        skos:definition "P72 has language"@en ;
        skos:prefLabel "P72 has language"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P73
crm:P73 rdf:type owl:ObjectProperty ;
        rdfs:domain crm:E34 ;
        rdfs:range epont:Translation ;
        skos:definition "P73 has translation"@en ;
        skos:prefLabel "P73 has translation"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P82
crm:P82 rdf:type owl:ObjectProperty ;
        rdfs:domain crm:E52 ;
        rdfs:range crm:E61 ;
        skos:definition "P82 at some time within"@en ;
        skos:prefLabel "P82 at some time within"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P90
crm:P90 rdf:type owl:ObjectProperty ;
        rdfs:domain crm:E54 ;
        rdfs:range crm:E60 ;
        skos:definition "P90 has value"@en ;
        skos:prefLabel "P90 has value"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P91
crm:P91 rdf:type owl:ObjectProperty ;
        rdfs:domain crm:E54 ;
        rdfs:range crm:E58 ;
        skos:altLabel "is unit of"@en ;
        skos:definition "P91 has unit"@en ;
        skos:prefLabel "P91 has unit"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P92
crm:P92 rdf:type owl:ObjectProperty ;
        rdfs:domain crm:E63 ;
        rdfs:range epont:Epigraphic_Support ;
        skos:altLabel "was brought into existence by"@en ;
        skos:definition "P92 brought into existence"@en ;
        skos:prefLabel "P92 brought into existence"@en .


###  http://www.cidoc-crm.org/cidoc-crm/P93
crm:P93 rdf:type owl:ObjectProperty ;
        rdfs:domain crm:E64 ;
        rdfs:range epont:Epigraphic_Support ;
        skos:altLabel "was taken out of existence by"@en ;
        skos:definition "P93 took out of existence"@en ;
        skos:prefLabel "P93 took out of existence"@en .


###  http://www.cidoc-crm.org/extensions/crmsci/O19
crmsci:O19 rdf:type owl:ObjectProperty ;
           rdfs:domain crmsci:S19 ;
           rdfs:range epont:Epigraphic_Support ;
           skos:altLabel "was object encountered through"@en ;
           skos:definition "O19 encountered object"@en ;
           skos:prefLabel "O19 encountered object"@en .


###  http://www.cidoc-crm.org/extensions/crmsci/O21
crmsci:O21 rdf:type owl:ObjectProperty ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( crmsci:S19
                                       crmsci:S21
                                     )
                       ] ;
           rdfs:range crm:E53 ;
           skos:altLabel "witnessed encounter"@en ;
           skos:definition "O21 encountered at"@en ;
           skos:prefLabel "O21 encountered at"@en .


###  http://www.cidoc-crm.org/extensions/crmsci/O24
crmsci:O24 rdf:type owl:ObjectProperty ;
           rdfs:domain crmsci:S21 ;
           rdfs:range epont:Epigraphic_Support ;
           skos:altLabel "was measured by"@en ;
           skos:definition "O24 measured"@en ;
           skos:prefLabel "O24 measured"@en .


###  http://www.cidoc-crm.org/extensions/crmsci/O9
crmsci:O9 rdf:type owl:ObjectProperty ;
          rdfs:domain crmsci:S21 ;
          rdfs:range crm:E57 ;
          skos:altLabel "property type was observed by"@en ;
          skos:definition "O9 observed property type"@en ;
          skos:prefLabel "O9 observed property type"@en .


###  http://www.cidoc-crm.org/extensions/crmtex/TXP2
crmtex:TXP2 rdf:type owl:ObjectProperty ;
            rdfs:domain crmtex:TX4 ;
            rdfs:range crmtex:TX1 ;
            skos:altLabel "is included within"@en ;
            skos:definition "TXP2 includes"@en ;
            skos:prefLabel "TXP2 includes"@en .


###  https://ontology.inscriptiones.org/epont/carriesText
epont:carriesText rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf crm:P56 ;
                  skos:altLabel "text is carried on"@en ;
                  skos:definition "carriesText"@en ;
                  skos:prefLabel "carriesText"@en .


###  https://ontology.inscriptiones.org/epont/has_edition
epont:has_edition rdf:type owl:ObjectProperty ;
                  rdfs:domain crm:E34 ;
                  rdfs:range epont:Edition ;
                  skos:altLabel "is edition of"@en ;
                  skos:definition "has edition"@en ;
                  skos:prefLabel "has edition"@en .


###  https://ontology.inscriptiones.org/epont/has_genre
epont:has_genre rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf crm:P2 ;
                rdfs:domain crm:E34 ;
                rdfs:range epont:Text_Genre ;
                skos:altLabel "genre is found in"@en ;
                skos:definition "has genre"@en ;
                skos:prefLabel "has genre"@en .


###  https://ontology.inscriptiones.org/epont/has_linguistic_property
epont:has_linguistic_property rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf crm:P165_incorporates ;
                              rdfs:domain crm:E34 ;
                              rdfs:range <https://ontology.inscriptiones.org/bilingualism> ;
                              skos:altLabel "linguistic property is found in"@en ;
                              skos:definition "has linguistic property"@en ;
                              skos:prefLabel "has linguistic property"@en .


