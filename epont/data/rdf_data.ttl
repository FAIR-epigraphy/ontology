                                                 rdfs:domain <http://www.cidoc-crm.org/extensions/crmsci/S19> ;
                                                 rdfs:range :Epigraphic_Support ;
                                                 <http://www.w3.org/2004/02/skos/core#altLabel> "was object encountered through"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "O19 encountered object"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "O19 encountered object"@en .


###  http://www.cidoc-crm.org/extensions/crmsci/O21
<http://www.cidoc-crm.org/extensions/crmsci/O21> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <http://www.cidoc-crm.org/extensions/crmsci/S19> ,
                                                             [ rdf:type owl:Class ;
                                                               owl:unionOf ( <http://www.cidoc-crm.org/extensions/crmsci/S19>
                                                                             <http://www.cidoc-crm.org/extensions/crmsci/S21>
                                                                           )
                                                             ] ;
                                                 rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E53> ;
                                                 <http://www.w3.org/2004/02/skos/core#altLabel> "witnessed encounter"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "O21 encountered at"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "O21 encountered at"@en .


###  http://www.cidoc-crm.org/extensions/crmsci/O24
<http://www.cidoc-crm.org/extensions/crmsci/O24> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <http://www.cidoc-crm.org/extensions/crmsci/S21> ;
                                                 rdfs:range :Epigraphic_Support ;
                                                 <http://www.w3.org/2004/02/skos/core#altLabel> "was measured by"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "O24 measured"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "O24 measured"@en .


###  http://www.cidoc-crm.org/extensions/crmsci/O9
<http://www.cidoc-crm.org/extensions/crmsci/O9> rdf:type owl:ObjectProperty ;
                                                rdfs:domain <http://www.cidoc-crm.org/extensions/crmsci/S21> ;
                                                rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E57> ;
                                                <http://www.w3.org/2004/02/skos/core#altLabel> "property type was observed by"@en ;
                                                <http://www.w3.org/2004/02/skos/core#definition> "O9 observed property type"@en ;
                                                <http://www.w3.org/2004/02/skos/core#prefLabel> "O9 observed property type"@en .


###  http://www.cidoc-crm.org/extensions/crmtex/TXP2
<http://www.cidoc-crm.org/extensions/crmtex/TXP2> rdf:type owl:ObjectProperty ;
                                                  rdfs:domain <http://www.cidoc-crm.org/extensions/crmtex/TX4> ;
                                                  rdfs:range <http://www.cidoc-crm.org/extensions/crmtex/TX1> ;
                                                  <http://www.w3.org/2004/02/skos/core#altLabel> "is included within"@en ;
                                                  <http://www.w3.org/2004/02/skos/core#definition> "TXP2 includes"@en ;
                                                  <http://www.w3.org/2004/02/skos/core#prefLabel> "TXP2 includes"@en ;
                                                  <http://www.w3.org/2004/02/skos/core#scopeNote> "This property describes the relation existing between a TX1 Written Text and the TX4 Writing Field, specifically created to accommodate the text, within which it is inscribed. This relation becomes quite relevant in the very frequent case where more than a single text is found on different areas of a specific support."^^xsd:string .


###  https://ontology.inscriptiones.org/epont/carriesText
:carriesText rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf <http://www.cidoc-crm.org/cidoc-crm/P56> ;
             rdfs:domain :Epigraphic_Support ;
             rdfs:range <http://www.cidoc-crm.org/extensions/crmtex/TX1> ;
             <http://www.w3.org/2004/02/skos/core#altLabel> "text is carried on"@en ;
             <http://www.w3.org/2004/02/skos/core#definition> "carriesText"@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "carriesText"@en .


###  https://ontology.inscriptiones.org/epont/has_edition
:has_edition rdf:type owl:ObjectProperty ;
             rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E34> ;
             rdfs:range :Edition ;
             <http://www.w3.org/2004/02/skos/core#altLabel> "is edition of"@en ;
             <http://www.w3.org/2004/02/skos/core#definition> "has edition"@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "has edition"@en ;
             <http://www.w3.org/2004/02/skos/core#scopeNote> "This property is a short-cut of the fully developed path TX1 Written Inscription : P128 carries : E34 Inscription : instantiates : F2 Expression: R76 (has derivative): F2 Expression : E33 Linguistic Object : R4 (is embodied in) : F3 Manifestation :dcterms:BibliographicResource"^^xsd:string .


###  https://ontology.inscriptiones.org/epont/has_genre
:has_genre rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf <http://www.cidoc-crm.org/cidoc-crm/P2> ;
           rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E34> ;
           rdfs:range :Text_Genre ;
           <http://www.w3.org/2004/02/skos/core#altLabel> "genre is found in"@en ;
           <http://www.w3.org/2004/02/skos/core#definition> "has genre"@en ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "has genre"@en .


###  https://ontology.inscriptiones.org/epont/has_linguistic_property
:has_linguistic_property rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf <http://www.cidoc-crm.org/cidoc-crm/P165_incorporates> ;
                         rdfs:domain <http://www.cidoc-crm.org/cidoc-crm/E34> ,
                                     <http://www.cidoc-crm.org/extensions/crmtex/TX1> ;
                         rdfs:range <https://ontology.inscriptiones.org/bilingualism> ;
                         <http://www.w3.org/2004/02/skos/core#altLabel> "linguistic property is found in"@en ;
                         <http://www.w3.org/2004/02/skos/core#definition> "has linguistic property"@en ;
                         <http://www.w3.org/2004/02/skos/core#prefLabel> "has linguistic property"@en .


###  https://ontology.inscriptiones.org/fair_epigraphy_ontology/has_support_condition
<https://ontology.inscriptiones.org/fair_epigraphy_ontology/has_support_condition> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                   rdfs:domain <http://www.cidoc-crm.org/extensions/crmtex/TX1> ;
                                                                                   rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E55> ;
                                                                                   <http://www.w3.org/2004/02/skos/core#definition> "describes the preservation state of the epigraphic support"@en ;
                                                                                   <http://www.w3.org/2004/02/skos/core#prefLabel> "has support condition"@en ;
                                                                                   <http://www.w3.org/2004/02/skos/core#scopeNote> "This property associates an instance of a TX1 written text with the description of the physical preservation state of the underlying epigraphic support. It is a short-cut for the fully developed path TX1 Written Inscription : P56 is found on : Epigraphic Support : P34 (was assessed by): E14 Condition Assessment: P35 has identified: E3 Condition State : P2 has type : E55 type"@en .


###  https://ontology.inscriptiones.org/fair_epigraphy_ontology/has_support_current_location
<https://ontology.inscriptiones.org/fair_epigraphy_ontology/has_support_current_location> rdf:type owl:ObjectProperty ;
                                                                                          rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                          rdfs:domain <http://www.cidoc-crm.org/extensions/crmtex/TX1> ;
                                                                                          rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E53> ;
                                                                                          <http://www.w3.org/2004/02/skos/core#definition> "describes the current location of the object (epigraphic support) on which the inscription is found"@en ;
                                                                                          <http://www.w3.org/2004/02/skos/core#prefLabel> "has support current location"@en ;
                                                                                          <http://www.w3.org/2004/02/skos/core#scopeNote> "This property associates an instance of a TX1 written text with the E53 Place where the object (epigraphic support) on which the inscription is to be found is currently located. It is a short-cut for the fully developed path TX1 Written Inscription : P56 is found on : Epigraphic Support : P55 has current location : E53 Place"@en .


###  https://ontology.inscriptiones.org/fair_epigraphy_ontology/has_support_dimension
<https://ontology.inscriptiones.org/fair_epigraphy_ontology/has_support_dimension> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                   rdfs:domain <http://www.cidoc-crm.org/extensions/crmtex/TX1> ;
                                                                                   rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E54> ;
                                                                                   <http://www.w3.org/2004/02/skos/core#definition> "describes a physical dimension (i.e. measurement) of the epigraphic support (e.g. height, width, etc.)."@en ;
                                                                                   <http://www.w3.org/2004/02/skos/core#prefLabel> "has support dimension"@en ;
                                                                                   <http://www.w3.org/2004/02/skos/core#scopeNote> "This property associates an instance of a TX1 written text with one or more physical dimensions of the epigraphic support on which it is found. It is a short cut of the fully developed path TX1 Written Inscription : P56 is found on : Epigraphic Support : P43 has dimension: E54 Dimension"@en .


###  https://ontology.inscriptiones.org/fair_epigraphy_ontology/has_support_findspot
<https://ontology.inscriptiones.org/fair_epigraphy_ontology/has_support_findspot> rdf:type owl:ObjectProperty ;
                                                                                  rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                  rdfs:domain <http://www.cidoc-crm.org/extensions/crmtex/TX1> ;
                                                                                  rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E53> ;
                                                                                  <http://www.w3.org/2004/02/skos/core#definition> "describes the findspot of the epigraphic support"@en ;
                                                                                  <http://www.w3.org/2004/02/skos/core#prefLabel> "has support findspot"@en ;
                                                                                  <http://www.w3.org/2004/02/skos/core#scopeNote> "This property associates an instance of a TX1 written text with the findspot of the epigraphic support on which the text is located. It is a short-cut of the fully developed path TX1 Written Inscription : P56 is found on : Epigraphic Support : O19 (was object encountered through) : S19 Encounter event : O21 encountered at : E53 Place"@en .


###  https://ontology.inscriptiones.org/fair_epigraphy_ontology/has_support_identifier
<https://ontology.inscriptiones.org/fair_epigraphy_ontology/has_support_identifier> rdf:type owl:ObjectProperty ;
                                                                                    rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                    rdfs:domain <http://www.cidoc-crm.org/extensions/crmtex/TX1> ;
                                                                                    rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E42> ;
                                                                                    <http://www.w3.org/2004/02/skos/core#definition> "details an identifier for the object (epigraphic support) on which the inscription is to be found"@en ;
                                                                                    <http://www.w3.org/2004/02/skos/core#prefLabel> "has support identifier"@en ;
                                                                                    <http://www.w3.org/2004/02/skos/core#scopeNote> "This property associates an instance of TX1 Written Text with an E42 Identifier for the epigraphic support on which the inscription is found. It is a short-cut for the fully developed path TX1 Written Inscription : P56 is found on : Epigraphic Support : P48 has preferred identifier: E42 Identifier"@en .


###  https://ontology.inscriptiones.org/fair_epigraphy_ontology/has_support_material
<https://ontology.inscriptiones.org/fair_epigraphy_ontology/has_support_material> rdf:type owl:ObjectProperty ;
                                                                                  rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                  rdfs:domain <http://www.cidoc-crm.org/extensions/crmtex/TX1> ;
                                                                                  rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E57> ;
                                                                                  <http://www.w3.org/2004/02/skos/core#definition> "defines the material of the epigraphic support which carries the inscription"@en ;
                                                                                  <http://www.w3.org/2004/02/skos/core#prefLabel> "has support material"@en ;
                                                                                  <http://www.w3.org/2004/02/skos/core#scopeNote> "This property associates an instance of a TX1 written text with the E57 material of which the epigraphic support which carries that text is constituted. It is a short cut for the fully developed path TX1 Written Inscription : P56 is found on : Epigraphic Support : P45 consists of : E57 Material"@en .


###  https://ontology.inscriptiones.org/fair_epigraphy_ontology/has_support_type
<https://ontology.inscriptiones.org/fair_epigraphy_ontology/has_support_type> rdf:type owl:ObjectProperty ;
                                                                              rdfs:subPropertyOf owl:topObjectProperty ;
                                                                              rdfs:domain <http://www.cidoc-crm.org/extensions/crmtex/TX1> ;
                                                                              rdfs:range <http://www.cidoc-crm.org/cidoc-crm/E55> ;
                                                                              <http://www.w3.org/2004/02/skos/core#definition> "describes the type of object which constitutes the epigraphic support"@en ;
                                                                              <http://www.w3.org/2004/02/skos/core#prefLabel> "has support type"@en ;
                                                                              <http://www.w3.org/2004/02/skos/core#scopeNote> "This property associates an instance of a TX1 written text with a classification of the object which constitutes the epigraphic support. It is a short-cut of the fully developed path TX1 Written Inscription : P56 is found on : Epigraphic Support : P2 has type: E55 type"@en .


