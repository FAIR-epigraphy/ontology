###  http://www.cidoc-crm.org/extensions/crmtex/TX1
<http://www.cidoc-crm.org/extensions/crmtex/TX1> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E25> ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "Visible or tactile marks (generally called glyphs or graphs), intentionally traced (i.e., “written”) on some kind of physical support by using specific techniques and tools, with the purpose of conveying a message towards a given receiver or group of receivers."@en ;
                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "TX1 Written Text"@en .


###  http://www.cidoc-crm.org/extensions/crmtex/TX4
<http://www.cidoc-crm.org/extensions/crmtex/TX4> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E25> ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "The portion of the physical carrier arranged and usually reserved and delimited for the purpose of accommodating a written text, highlighting and isolating it from the other parts of the object to which it belongs, enhancing and guaranteeing its readability."@en ;
                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "TX4 Writing Field"@en .


###  https://ontology.inscriptiones.org/bilingualism
<https://ontology.inscriptiones.org/bilingualism> rdf:type owl:Class ;
                                                  rdfs:subClassOf owl:Thing ;
                                                  <http://www.w3.org/2004/02/skos/core#definition> "elements in an inscription which indicate the concurrent use, or evidence of the presence of, two or more languages, for example Latin/Greek/'indigenous' languages, and which may therefore reflect societal and/or individual bilingualism/multilingualism. This is split into two main sub-categories, language-focused and script-focused, and the same epigraphic texts may contain multiple features, including from both main sub-categories."@en ;
                                                  <http://www.w3.org/2004/02/skos/core#prefLabel> "Bilingualism Feature"@en .


###  https://ontology.inscriptiones.org/epont/Edition
:Edition rdf:type owl:Class ;
         rdfs:subClassOf <http://iflastandards.info/ns/lrm/lrmoo/F3_Manifestation> ;
         <http://www.w3.org/2004/02/skos/core#definition> "An epigraphic edition, an interpreted version of the epigraphic text, generally the end-result of a process of checking, intepreting and preparing a version of the epigraphic text for wider dissemination; usually, but not necessarily, a publication."@en ;
         <http://www.w3.org/2004/02/skos/core#prefLabel> "Edition"@en .


###  https://ontology.inscriptiones.org/epont/Epigraphic_Support
:Epigraphic_Support rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E24> ;
                    <http://www.w3.org/2004/02/skos/core#definition> "The physical carrier of an inscription — the object on which the text was written (stone tablet, metal sheet, ceramic vessel, rock face, etc.)."@en ;
                    <http://www.w3.org/2004/02/skos/core#prefLabel> "Epigraphic Support"@en .


###  https://ontology.inscriptiones.org/epont/Text_Genre
:Text_Genre rdf:type owl:Class ;
            rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55> ;
            <http://www.w3.org/2004/02/skos/core#definition> "The form of written language employed in the inscription, at its highest level distinguishing between prose and verse"@en ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "Text Genre"@en ;
            <http://www.w3.org/2004/02/skos/core#scopeNote> "This class is intended primarily for the distinction between prose and verse, and the sub-categories thereof; it is not intended to describe the functional genres of inscriptions (such as letter, decree, epitaph, etc.)."^^xsd:string .


